          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{9F73F339-0C52-4737-99F5-7767A779CB57}"
              SQLTask:SqlStatementSource="INSERT INTO dw.DimJobTitle&#xA;(&#xA;    JobTitleId,&#xA;    JobTitleName,&#xA;    JobLevel&#xA;)&#xA;SELECT&#xA;    s.JobTitleId,&#xA;    s.JobTitleName,&#xA;    s.JobLevel&#xA;FROM stg.vJobTitle_Clean s;&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
