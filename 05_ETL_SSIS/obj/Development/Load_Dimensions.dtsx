      <DTS:Variables />
      <DTS:Executables>
        <DTS:Executable
          DTS:refId="Package\Sequence Container\01 Load DimDate"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{C637E922-325D-410F-A2E3-35CD41380642}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="01 Load DimDate"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{9F73F339-0C52-4737-99F5-7767A779CB57}"
              SQLTask:SqlStatementSource="DECLARE @StartDate DATE = '2025-01-01';&#xA;DECLARE @EndDate   DATE = '2026-12-31';&#xA;&#xA;;WITH DateSeries AS&#xA;(&#xA;    SELECT @StartDate AS [Date]&#xA;    UNION ALL&#xA;    SELECT DATEADD(DAY, 1, [Date])&#xA;    FROM DateSeries&#xA;    WHERE [Date] &lt; @EndDate&#xA;)&#xA;INSERT INTO dw.DimDate&#xA;(&#xA;    DateKey,&#xA;    [Date],&#xA;    [Year],&#xA;    [Quarter],&#xA;    [Month],&#xA;    MonthName,&#xA;    [Day],&#xA;    DayName,&#xA;    IsWeekend&#xA;)&#xA;SELECT&#xA;    CAST(CONVERT(CHAR(8), [Date], 112) AS INT) AS DateKey,&#xA;    [Date],&#xA;    YEAR([Date]) AS [Year],&#xA;    DATEPART(QUARTER, [Date]) AS [Quarter],&#xA;    MONTH([Date]) AS [Month],&#xA;    DATENAME(MONTH, [Date]) AS MonthName,&#xA;    DAY([Date]) AS [Day],&#xA;    DATENAME(WEEKDAY, [Date]) AS DayName,&#xA;    CASE&#xA;        WHEN DATENAME(WEEKDAY, [Date]) IN ('Saturday', 'Sunday') THEN 1&#xA;        ELSE 0&#xA;    END AS IsWeekend&#xA;FROM DateSeries&#xA;OPTION (MAXRECURSION 0);&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\Sequence Container\02 Load DimDepartment"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{D047B08F-4F86-4662-8F29-CD9E0C626F7F}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="02 Load DimDepartment"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{9F73F339-0C52-4737-99F5-7767A779CB57}"
              SQLTask:SqlStatementSource="INSERT INTO dw.DimDepartment&#xA;(DepartmentId, DepartmentName, CostCenter, LocationName, Region)&#xA;SELECT&#xA;    d.DepartmentId,&#xA;    d.DepartmentName,&#xA;    d.CostCenter,&#xA;    l.LocationName,&#xA;    l.Region&#xA;FROM stg.vDepartment_Clean d&#xA;JOIN stg.vLocation_Clean l&#xA;    ON d.LocationId = l.LocationId;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\Sequence Container\03 Load DimJobTitle"
