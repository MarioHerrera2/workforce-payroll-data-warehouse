    <DTS:Executable
      DTS:refId="Package\Validation"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{134E4CED-5898-4792-8947-A8B3B25E92D1}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Validation"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{9F73F339-0C52-4737-99F5-7767A779CB57}"
          SQLTask:SqlStatementSource="BEGIN TRY&#xA;&#xA;    IF EXISTS (&#xA;        SELECT 1&#xA;        FROM dw.FactPayroll&#xA;        WHERE EmployeeKey IS NULL&#xA;    )&#xA;    THROW 50001, 'Missing EmployeeKey', 1;&#xA;&#xA;END TRY&#xA;BEGIN CATCH&#xA;&#xA;    INSERT INTO etl.ETL_RunLog&#xA;    (PackageName, StartTime, EndTime, Status, ErrorMessage)&#xA;    VALUES&#xA;    ('Load_FactPayroll', GETDATE(), GETDATE(), 'FAILED', ERROR_MESSAGE());&#xA;&#xA;    THROW;&#xA;&#xA;END CATCH;&#xA;&#xA;&#xA;/* DIMENSIONS VALIDATION */&#xA;IF NOT EXISTS (SELECT 1 FROM dw.DimDate)&#xA;    THROW 50030, 'Dimensions failed: DimDate has no rows.', 1;&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM dw.DimEmployee)&#xA;    THROW 50031, 'Dimensions failed: DimEmployee has no rows.', 1;&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM dw.DimDepartment)&#xA;    THROW 50032, 'Dimensions failed: DimDepartment has no rows.', 1;&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM dw.DimPayType)&#xA;    THROW 50033, 'Dimensions failed: DimPayType has no rows.', 1;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
