              SQLTask:SqlStatementSource="INSERT INTO dw.DimPayType&#xA;(&#xA;    PayTypeId,&#xA;    PayTypeName&#xA;)&#xA;SELECT&#xA;    s.PayTypeId,&#xA;    s.PayTypeName&#xA;FROM stg.vPayType_Clean s;&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
