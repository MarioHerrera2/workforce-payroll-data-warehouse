  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Load FactPayroll"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{7D730138-533F-4A31-B986-FCE415EA2108}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load FactPayroll"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{A75E0C20-66B3-4FAD-8E44-5D4A933F0666}"
          SQLTask:SqlStatementSource="INSERT INTO dw.FactPayroll&#xA;(&#xA;    EmployeeKey,&#xA;    DepartmentKey,&#xA;    JobTitleKey,&#xA;    PayTypeKey,&#xA;    PayDateKey,&#xA;    RegularHours,&#xA;    OvertimeHours,&#xA;    GrossPay,&#xA;    BonusPay,&#xA;    DeductionAmount,&#xA;    NetPay&#xA;)&#xA;SELECT&#xA;    de.EmployeeKey,&#xA;    dd.DepartmentKey,&#xA;    djt.JobTitleKey,&#xA;    dpt.PayTypeKey,&#xA;    ddte.DateKey,&#xA;    p.RegularHours,&#xA;    p.OvertimeHours,&#xA;    p.GrossPay,&#xA;    p.BonusPay,&#xA;    p.DeductionAmount,&#xA;    p.NetPay&#xA;FROM stg.vPayrollTransaction_Clean p&#xA;JOIN dw.DimEmployee de&#xA;    ON p.EmployeeId = de.EmployeeId&#xA;JOIN dw.DimDepartment dd&#xA;    ON de.DepartmentName = dd.DepartmentName&#xA;JOIN dw.DimJobTitle djt&#xA;    ON de.JobTitleName = djt.JobTitleName&#xA;JOIN dw.DimPayType dpt&#xA;    ON de.PayTypeName = dpt.PayTypeName&#xA;JOIN dw.DimDate ddte&#xA;    ON p.PaymentDate = ddte.[Date];&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Log FactPayroll Success"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{01189889-7DBC-466C-B4D1-BC94A33C98A4}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Log FactPayroll Success"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{A75E0C20-66B3-4FAD-8E44-5D4A933F0666}"
          SQLTask:SqlStatementSource="UPDATE etl.ETL_RunLog&#xA;SET&#xA;    EndTime = GETDATE(),&#xA;    Status = 'SUCCESS',&#xA;    RowsLoaded = (SELECT COUNT(*) FROM dw.FactPayroll),&#xA;    ErrorMessage = NULL&#xA;WHERE RunId = (&#xA;    SELECT MAX(RunId)&#xA;    FROM etl.ETL_RunLog&#xA;    WHERE PackageName = 'Load_FactPayroll'&#xA;      AND Status = 'STARTED'&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Log Package Failure"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{1A8B90B1-868E-4E87-B13E-F7DA1658DC60}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Log Package Failure"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{A75E0C20-66B3-4FAD-8E44-5D4A933F0666}"
          SQLTask:SqlStatementSource="UPDATE etl.ETL_RunLog&#xA;SET&#xA;    EndTime = GETDATE(),&#xA;    Status = 'FAILED',&#xA;    ErrorMessage = 'Load_FactPayroll package failed.'&#xA;WHERE RunId = (&#xA;    SELECT MAX(RunId)&#xA;    FROM etl.ETL_RunLog&#xA;    WHERE PackageName = 'Load_FactPayroll'&#xA;      AND Status = 'STARTED'&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Log Package Start"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{D1289463-5014-4C50-BCAE-2D542E41203B}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Log Package Start"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{A75E0C20-66B3-4FAD-8E44-5D4A933F0666}"
          SQLTask:SqlStatementSource="INSERT INTO etl.ETL_RunLog&#xA;(&#xA;    PackageName,&#xA;    StartTime,&#xA;    EndTime,&#xA;    Status,&#xA;    RowsLoaded,&#xA;    ErrorMessage&#xA;)&#xA;VALUES&#xA;(&#xA;    'Load_FactPayroll',&#xA;    GETDATE(),&#xA;    GETDATE(),&#xA;    'SUCCESS',&#xA;    (SELECT COUNT(*) FROM dw.FactPayroll),&#xA;    NULL&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Truncate FactPayroll"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{BD044E5F-734E-473E-BAE7-1CE060C29A4E}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Truncate FactPayroll"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{A75E0C20-66B3-4FAD-8E44-5D4A933F0666}"
          SQLTask:SqlStatementSource="truncate table dw.factpayroll;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Validation"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{6940EFFA-ACE6-46E4-8C14-2DA02308822C}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Validation"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{A75E0C20-66B3-4FAD-8E44-5D4A933F0666}"
          SQLTask:SqlStatementSource="IF EXISTS (&#xA;    SELECT 1&#xA;    FROM dw.FactPayroll&#xA;    WHERE EmployeeKey IS NULL&#xA;       OR DepartmentKey IS NULL&#xA;       OR JobTitleKey IS NULL&#xA;       OR PayTypeKey IS NULL&#xA;       OR PayDateKey IS NULL&#xA;)&#xA;THROW 50001, 'FactPayroll validation failed: missing dimension key.', 1;&#xA;&#xA;DECLARE @stg INT, @fact INT;&#xA;&#xA;SELECT @stg = COUNT(*) FROM stg.vPayrollTransaction_Clean;&#xA;SELECT @fact = COUNT(*) FROM dw.FactPayroll;&#xA;&#xA;IF @stg &lt;&gt; @fact&#xA;THROW 50002, 'FactPayroll validation failed: row count mismatch.', 1;&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM dw.FactPayroll)&#xA;THROW 50003, 'FactPayroll validation failed: no rows loaded.', 1;&#xA;&#xA;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
