          SQLTask:SqlStatementSource="INSERT INTO etl.ETL_RunLog&#xA;(PackageName, StartTime, Status)&#xA;VALUES ('Load_Staging_From_OLTP', GETDATE(), 'STARTED');" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
